@model IEnumerable<ofis_ici_yemek_secim_sistemi.Models.Food>
@{
    var categories = ViewBag.Categories as Dictionary<int, string>;
}

<div class="card shadow-sm border-0" style="border-radius:12px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="padding:1rem 1.5rem;">Yemek Adı</th>
                    <th>Kategori</th>
                    <th>İçindekiler</th>
                    <th>Açıklama</th>
                    <th>Alerjen</th>
                    <th>Durum</th>
                    <th style="min-width:220px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="@(!item.IsActive ? "table-secondary opacity-75" : "")">
                            <td style="padding:1rem 1.5rem;" class="fw-semibold text-dark">@item.Name</td>
                            <td>
                                @if (item.CategoryID.HasValue && categories != null && categories.ContainsKey(item.CategoryID.Value))
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1" style="border-radius:6px;">
                                        @categories[item.CategoryID.Value]
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-muted small">
                                @(string.IsNullOrEmpty(item.Ingredients) ? "—" : (item.Ingredients.Length > 60 ? item.Ingredients.Substring(0, 60) + "..." : item.Ingredients))
                            </td>
                            <td class="text-muted small">
                                @(string.IsNullOrEmpty(item.Description) ? "—" : (item.Description.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description))
                            </td>
                            <td class="text-muted small">@(string.IsNullOrEmpty(item.Allergens) ? "—" : item.Allergens)</td>
                            <td>
                                @using (Html.BeginForm("ToggleFoodStatus", "Food", new { id = item.ID }, FormMethod.Post, new { @class = "d-inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="button" class="btn-toggle-status border-0 bg-transparent p-0"
                                            title="Durumu değiştirmek için tıklayın">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1" style="border-radius:6px;">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1" style="border-radius:6px;">Pasif</span>
                                        }
                                    </button>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="@Url.Action("EditFood", "Food", new { id = item.ID })"
                                       class="btn btn-sm btn-outline-primary btn-edit-ajax"
                                       data-title="Yemek Düzenle"
                                       title="Düzenle">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    @using (Html.BeginForm("DeleteFood", "Food", new { id = item.ID }, FormMethod.Post, new { @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger btn-delete-food"
                                                data-name="@item.Name"
                                                title="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-bowl-food d-block fs-1 mb-2 text-black-50"></i>
                            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                            {
                                <span>Aramanızla eşleşen yemek bulunamadı.</span>
                            }
                            else
                            {
                                <span>Henüz kataloğunuzda yemek bulunmamaktadır.</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>