@{
    Layout = null;
    ViewBag.Title = "Giriş Yap";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Ofis Yemek Seçim</title>
    @Styles.Render("~/Content/css")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(160deg, #f1f5f9 0%, #e2e8f0 50%, #f8fafc 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-container {
            width: 100%;
            max-width: 440px;
            padding: 20px;
        }

        .login-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.08), 0 5px 15px rgba(0, 0, 0, 0.03);
            padding: 3rem 2.5rem;
            position: relative;
            overflow: hidden;
        }

       
            .login-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 4px;
                background: linear-gradient(90deg, #3b82f6, #60a5fa);
                border-radius: 0 0 4px 4px;
            }

   
        .login-brand {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .logo-wrapper {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 100px;
            height: 100px;
            background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
            border-radius: 50%;
            margin-bottom: 1.5rem;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04), inset 0 2px 4px rgba(255, 255, 255, 0.9);
            position: relative;
        }

            .logo-wrapper::before {
                content: '';
                position: absolute;
                width: 86px;
                height: 86px;
                border-radius: 50%;
                border: 2px solid #e2e8f0;
            }

            .logo-wrapper::after {
                content: '';
                position: absolute;
                width: 72px;
                height: 72px;
                border-radius: 50%;
                border: 1px dashed #cbd5e1;
                opacity: 0.5;
            }

        .logo-icon {
            font-size: 42px;
            color: #3b82f6;
            position: relative;
            z-index: 2;
        }

        .brand-name {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1e293b;
            letter-spacing: -0.03em;
            margin-bottom: 0.25rem;
        }

        .brand-accent {
            color: #3b82f6;
        }

        .brand-tagline {
            font-size: 0.8rem;
            color: #64748b;
            font-weight: 500;
            letter-spacing: 0.02em;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-label {
            display: block;
            font-size: 0.813rem;
            font-weight: 600;
            color: #475569;
            margin-bottom: 0.5rem;
        }

        .form-input {
            width: 100%;
            max-width: 100%;
            display: block;
            padding: 0.875rem 1rem;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 0.938rem;
            color: #1e293b;
            transition: all 0.2s ease;
            background: #f8fafc;
            box-sizing: border-box;
        }

            .form-input:hover {
                border-color: #cbd5e1;
            }

            .form-input:focus {
                outline: none;
                border-color: #3b82f6;
                background: white;
                box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.08);
            }

            .form-input::placeholder {
                color: #94a3b8;
            }

       
        .alert {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-left: 3px solid #ef4444;
            color: #dc2626;
            padding: 0.875rem 1rem;
            border-radius: 10px;
            font-size: 0.813rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.625rem;
        }

            .alert i {
                font-size: 16px;
            }

       
        .btn-login {
            width: 100%;
            padding: 0.875rem;
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            color: white;
            border: 2px solid transparent;
            border-radius: 12px;
            font-size: 0.938rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 0.5rem;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(59, 130, 246, 0.35), 0 4px 10px rgba(37, 99, 235, 0.2);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        .login-footer {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 1.5rem;
            margin-top: 1.75rem;
            padding-top: 1.75rem;
            border-top: 1px solid #f1f5f9;
        }

   
        .link-forgot {
            font-size: 0.813rem;
            color: #64748b;
            text-decoration: none;
            font-weight: 400;
            transition: color 0.2s;
            position: relative;
        }

            .link-forgot::after {
                content: '';
                position: absolute;
                bottom: -2px;
                left: 0;
                width: 0;
                height: 1px;
                background: #64748b;
                transition: width 0.2s;
            }

            .link-forgot:hover {
                color: #3b82f6;
            }

                .link-forgot:hover::after {
                    width: 100%;
                    background: #3b82f6;
                }

  
        .btn-register {
            font-size: 0.813rem;
            font-weight: 600;
            color: #3b82f6;
            text-decoration: none;
            padding: 0.5rem 1.25rem;
            border: 2px solid #3b82f6;
            border-radius: 20px;
            transition: background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
            background: transparent;
            position: relative;
            box-sizing: border-box;
            display: inline-block;
        }

            .btn-register:hover {
                background: #3b82f6;
                color: #ffffff;
                box-shadow: 0 4px 15px rgba(59, 130, 246, 0.25);
            }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">

            <div class="login-brand">
                <div class="logo-wrapper">
                    <i class="fa-solid fa-utensils logo-icon"></i>
                </div>
                <h1 class="brand-name">Ofis<span class="brand-accent">Yemek</span></h1>
                <p class="brand-tagline">Personel Yemek Seçim Sistemi</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    @ViewBag.Error
                </div>
            }

            <form method="post" action="@Url.Action("Login", "Account")">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label" for="email">E-posta Adresi</label>
                    <input type="email"
                           name="email"
                           id="email"
                           class="form-input"
                           placeholder="ornek@sirket.com"
                           required
                           autofocus />
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">Şifre</label>
                    <input type="password"
                           name="password"
                           id="password"
                           class="form-input"
                           placeholder="••••••••"
                           required />
                </div>

                <button type="submit" class="btn-login">
                    <i class="fa-solid fa-right-from-bracket"></i> Giriş Yap
                </button>
            </form>

            <div class="login-footer">
                <a href="#" class="link-forgot">Şifremi Unuttum</a>
                <a href="@Url.Action("Register", "Account")" class="btn-register">Kayıt Ol</a>
            </div>

        </div>
    </div>
</body>
</html>