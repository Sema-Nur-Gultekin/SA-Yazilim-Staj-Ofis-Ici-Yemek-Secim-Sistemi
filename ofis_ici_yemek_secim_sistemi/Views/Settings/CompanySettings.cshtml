@model ofis_ici_yemek_secim_sistemi.Models.Company
@{
    ViewBag.Title = "Şirket Ayarları";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h4 class="mb-0 text-dark"><i class="fa-solid fa-building text-primary"></i> Kurumsal Ayarlar</h4>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> @ViewBag.SuccessMessage</div>
                    }

                    <form action="@Url.Action("CompanySettings", "Settings")" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-bold">Şirket Unvanı</label>
                            <input type="text" name="Name" class="form-control" value="@Model.Name" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Vergi Numarası</label>
                                <input type="text" name="TaxNumber" class="form-control" value="@Model.TaxNumber" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">İletişim E-posta</label>
                                <input type="email" name="ContactEmail" class="form-control" value="@Model.ContactEmail" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">İletişim Telefonu</label>
                            <input type="text" name="ContactPhone" class="form-control" value="@Model.ContactPhone" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Şirket Adresi</label>
                            <textarea name="Address" class="form-control" rows="3">@Model.Address</textarea>
                        </div>

                        <button type="submit" class="btn btn-primary px-4 py-2">
                            <i class="fa-solid fa-building-circle-check"></i> Kurumsal Bilgileri Kaydet
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>