@model ofis_ici_yemek_secim_sistemi.Models.User
@{
    ViewBag.Title = "Profil Ayarları";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h4 class="mb-0 text-dark"><i class="fa-solid fa-user-gear text-primary"></i> Kişisel Bilgilerim</h4>
                </div>
                <div class="card-body p-4">

                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success"><i class="fa-solid fa-check-circle"></i> @ViewBag.SuccessMessage</div>
                    }

                    <form action="@Url.Action("UserSettings", "Settings")" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-bold">E-posta (Değiştirilemez)</label>
                            <input type="email" class="form-control bg-light" value="@Model.Email" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ad Soyad</label>
                            <input type="text" name="Name" class="form-control" value="@Model.Name" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Departman</label>
                                <input type="text" name="Department" class="form-control" value="@Model.Department" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Lokasyon</label>
                                <input type="text" name="Location" class="form-control" value="@Model.Location" />
                            </div>
                        </div>

                        <hr class="my-4" />
                        <h5 class="mb-3">Şifre Değiştir (İsteğe Bağlı)</h5>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Yeni Şifre</label>
                            <input type="password" name="newPassword" class="form-control" placeholder="Değiştirmek istemiyorsanız boş bırakın" />
                        </div>

                        <button type="submit" class="btn btn-primary px-4 py-2">
                            <i class="fa-solid fa-save"></i> Değişiklikleri Kaydet
                        </button>
                    </form>

                    @if (User.IsInRole("User"))
                    {
                        <hr class="my-4" />
                        <div class="alert alert-danger d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Dikkat:</strong> Hesabınızı kalıcı olarak silmek istiyorsanız bu işlemi geri alamazsınız.
                            </div>
                            <form action="@Url.Action("DeleteUserAccount", "Settings")" method="post" onsubmit="return confirm('Hesabınızı kalıcı olarak silmek istediğinize emin misiniz? Bu işlem geri alınamaz!');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm">Hesabımı Sil</button>
                            </form>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>