@model IEnumerable<ofis_ici_yemek_secim_sistemi.Models.FoodCategory>

<div class="card shadow-sm border-0" style="border-radius:12px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="padding:1rem 1.5rem; width:80px;">Sıra</th>
                    <th>Kategori Adı</th>
                    <th>Açıklama</th>
                    <th>Durum</th>
                    <th style="min-width:220px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="@(!item.IsActive ? "table-secondary opacity-75" : "")">
                            <td style="padding:1rem 1.5rem;" class="text-muted fw-bold">
                                @(item.DisplayOrder.HasValue ? item.DisplayOrder.Value.ToString() : "—")
                            </td>
                            <td class="fw-semibold text-dark">@item.Name</td>
                            <td class="text-muted small">
                                @(string.IsNullOrEmpty(item.Description) ? "—" : item.Description)
                            </td>
                            <td>
                                @using (Html.BeginForm("ToggleCategoryStatus", "Category", new { id = item.ID }, FormMethod.Post, new { @class = "d-inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="button" class="btn-toggle-status border-0 bg-transparent p-0"
                                            title="Durumu değiştirmek için tıklayın">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1" style="border-radius:6px;">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1" style="border-radius:6px;">Pasif</span>
                                        }
                                    </button>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="@Url.Action("EditCategory", "Category", new { id = item.ID })"
                                       class="btn btn-sm btn-outline-primary btn-edit-ajax"
                                       data-title="Kategori Düzenle"
                                       title="Düzenle">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>

                                    @using (Html.BeginForm("DeleteCategory", "Category", new { id = item.ID }, FormMethod.Post, new { @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger btn-delete-category"
                                                data-name="@item.Name"
                                                title="Sil">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-tags d-block fs-1 mb-2 text-black-50"></i>
                            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                            {
                                <span>Aramanızla eşleşen kategori bulunamadı.</span>
                            }
                            else
                            {
                                <span>Henüz eklenmiş bir kategori bulunmamaktadır.</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>