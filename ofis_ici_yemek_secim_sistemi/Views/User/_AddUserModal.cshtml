@model ofis_ici_yemek_secim_sistemi.Models.User

<form action="@Url.Action("AddUser", "User")" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label fw-semibold">Ad Soyad <span class="text-danger">*</span></label>
        <input type="text" name="Name" class="form-control py-2" placeholder="Ad Soyad" required maxlength="100" style="border-radius:8px;" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">E-posta <span class="text-danger">*</span></label>
        <input type="email" name="Email" class="form-control py-2" placeholder="ornek@sirket.com" required maxlength="150" style="border-radius:8px;" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Şifre <span class="text-danger">*</span></label>
        <input type="password" name="password" class="form-control py-2" placeholder="••••••••" required style="border-radius:8px;" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Rol <span class="text-danger">*</span></label>
        <select name="Role" class="form-select py-2" required style="border-radius:8px;">
            <option value="">— Rol Seçin —</option>
            <option value="User">Standart Kullanıcı (Personel)</option>
            <option value="Admin">Şirket Admini</option>
        </select>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label fw-semibold">Departman</label>
            <input type="text" name="Department" class="form-control py-2" placeholder="Örn: Yazılım" maxlength="100" style="border-radius:8px;" />
        </div>
        <div class="col-md-6">
            <label class="form-label fw-semibold">Lokasyon</label>
            <input type="text" name="Location" class="form-control py-2" placeholder="Örn: İstanbul Ofis" maxlength="100" style="border-radius:8px;" />
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">İptal</button>
        <button type="submit" class="btn btn-primary" data-original-text="<i class='fa-solid fa-user-plus me-1'></i>Kullanıcı Ekle">
            <i class="fa-solid fa-user-plus me-1"></i>Kullanıcı Ekle
        </button>
    </div>
</form>