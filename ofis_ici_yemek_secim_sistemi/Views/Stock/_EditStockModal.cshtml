@model ofis_ici_yemek_secim_sistemi.Models.StockItem

<form action="@Url.Action("EditStock", "Stock", new { id = Model.ID })" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label fw-semibold">Malzeme Adı <span class="text-danger">*</span></label>
        <input type="text" name="Name" class="form-control py-2" value="@Model.Name" required maxlength="150" style="border-radius:8px;" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Birim <span class="text-danger">*</span></label>
        <select name="Unit" class="form-select py-2" required style="border-radius:8px;">
            <option value="kg" @(Model.Unit == "kg" ? "selected" : "")>Kilogram (kg)</option>
            <option value="lt" @(Model.Unit == "lt" ? "selected" : "")>Litre (lt)</option>
            <option value="adet" @(Model.Unit == "adet" ? "selected" : "")>Adet</option>
            <option value="paket" @(Model.Unit == "paket" ? "selected" : "")>Paket</option>
            <option value="gr" @(Model.Unit == "gr" ? "selected" : "")>Gram (gr)</option>
            <option value="ml" @(Model.Unit == "ml" ? "selected" : "")>Mililitre (ml)</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Mevcut Stok Miktarı</label>
        <input type="number" name="CurrentQuantity" class="form-control py-2" step="0.01"
               value="@(Model.CurrentQuantity.HasValue ? Model.CurrentQuantity.Value.ToString("F2") : "")" style="border-radius:8px;" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Minimum Stok Seviyesi</label>
        <input type="number" name="MinimumQuantity" class="form-control py-2" step="0.01"
               value="@(Model.MinimumQuantity.HasValue ? Model.MinimumQuantity.Value.ToString("F2") : "")" style="border-radius:8px;" />
    </div>

    <div class="mb-4 form-check form-switch">
        <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="isActiveSwitch" @(Model.IsActive ? "checked" : "") />
        <label class="form-check-label fw-semibold" for="isActiveSwitch">Aktif</label>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">İptal</button>
        <button type="submit" class="btn btn-primary" data-original-text="<i class='fa-solid fa-floppy-disk me-1'></i>Güncelle">
            <i class="fa-solid fa-floppy-disk me-1"></i>Güncelle
        </button>
    </div>
</form>