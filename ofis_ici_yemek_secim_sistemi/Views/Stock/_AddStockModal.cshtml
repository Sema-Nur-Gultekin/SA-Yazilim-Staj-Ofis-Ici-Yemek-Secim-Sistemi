@model ofis_ici_yemek_secim_sistemi.Models.StockItem

<form action="@Url.Action("AddStock", "Stock")" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label fw-semibold">Malzeme Adı <span class="text-danger">*</span></label>
        <input type="text" name="Name" class="form-control py-2" placeholder="Örn: Pirinç" required maxlength="150" style="border-radius:8px;" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Birim <span class="text-danger">*</span></label>
        <select name="Unit" class="form-select py-2" required style="border-radius:8px;">
            <option value="">— Birim Seçin —</option>
            <option value="kg">Kilogram (kg)</option>
            <option value="lt">Litre (lt)</option>
            <option value="adet">Adet</option>
            <option value="paket">Paket</option>
            <option value="gr">Gram (gr)</option>
            <option value="ml">Mililitre (ml)</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Başlangıç Stok Miktarı</label>
        <input type="number" name="CurrentQuantity" class="form-control py-2" step="0.01" placeholder="Örn: 50" style="border-radius:8px;" />
    </div>

    <div class="mb-4">
        <label class="form-label fw-semibold">Minimum Stok Seviyesi</label>
        <input type="number" name="MinimumQuantity" class="form-control py-2" step="0.01" placeholder="Örn: 5" style="border-radius:8px;" />
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">İptal</button>
        <button type="submit" class="btn btn-primary" data-original-text="<i class='fa-solid fa-floppy-disk me-1'></i>Kaydet">
            <i class="fa-solid fa-floppy-disk me-1"></i>Kaydet
        </button>
    </div>
</form>