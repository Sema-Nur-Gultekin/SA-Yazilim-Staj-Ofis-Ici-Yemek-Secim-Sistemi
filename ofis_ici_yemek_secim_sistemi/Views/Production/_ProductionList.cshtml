@model IEnumerable<ofis_ici_yemek_secim_sistemi.Models.ProductionRecord>
@{
    var foodNames = ViewBag.FoodNames as Dictionary<int, string>;
}

<div class="card shadow-sm border-0" style="border-radius:12px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="padding:1rem 1.5rem;">Tarih</th>
                    <th>Öğün</th>
                    <th>Yemek</th>
                    <th>Planlanan</th>
                    <th>Üretilen</th>
                    <th>Tüketilen</th>
                    <th>Not</th>
                    <th style="min-width:120px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        string foodName = (foodNames != null && foodNames.ContainsKey(item.FoodID)) ? foodNames[item.FoodID] : "Bilinmeyen";
                        <tr>
                            <td style="padding:1rem 1.5rem;" class="fw-semibold">@item.Date.ToString("dd.MM.yyyy")</td>
                            <td><span class="badge bg-secondary-subtle text-secondary px-2 py-1" style="border-radius:6px;">@item.MealType</span></td>
                            <td class="text-dark">@foodName</td>
                            <td>@(item.PlannedDemandQuantity?.ToString() ?? "—")</td>
                            <td>@(item.ProducedQuantity?.ToString() ?? "—")</td>
                            <td>@(item.ActualConsumedQuantity?.ToString() ?? "—")</td>
                            <td class="text-muted small">@(string.IsNullOrEmpty(item.Note) ? "—" : item.Note)</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("EditProduction", "Production", new { id = item.ID })"
                                       class="btn btn-sm btn-outline-primary btn-edit-ajax"
                                       data-title="Üretim Kaydı Düzenle"
                                       title="Düzenle">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    @using (Html.BeginForm("DeleteProduction", "Production", new { id = item.ID }, FormMethod.Post, new { @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil"
                                                onclick="return confirm('Bu üretim kaydını silmek istediğinize emin misiniz?')">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-industry d-block fs-1 mb-2 text-black-50"></i>
                            Henüz üretim kaydı girilmemiş.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>