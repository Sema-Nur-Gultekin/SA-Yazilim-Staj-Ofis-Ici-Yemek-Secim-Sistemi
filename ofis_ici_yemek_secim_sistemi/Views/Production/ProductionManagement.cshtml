@model IEnumerable<ofis_ici_yemek_secim_sistemi.Models.ProductionRecord>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Üretim / Pişirim Kayıtları";
    var foodNames = ViewBag.FoodNames as Dictionary<int, string>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-dark m-0">Üretim / Pişirim Kayıtları</h3>
        <p class="text-muted small m-0">Planlanan ve gerçekleşen üretim adetlerini takip edin.</p>
    </div>
    <a href="@Url.Action("AddProduction", "Production")"
       class="btn btn-primary fw-semibold px-4 py-2 btn-add-ajax"
       data-title="Yeni Üretim Kaydı"
       style="border-radius:8px;">
        <i class="fa-solid fa-plus me-2"></i>Yeni Kayıt Ekle
    </a>
</div>

<div id="tableContainer" data-refresh-url="@Url.Action("ProductionManagement", "Production")">
    @Html.Partial("_ProductionList", Model)
</div>