@model ofis_ici_yemek_secim_sistemi.Models.RecipeIngredient
@{
    var foods = ViewBag.Foods as List<ofis_ici_yemek_secim_sistemi.Models.Food>;
    var stockItems = ViewBag.StockItems as List<ofis_ici_yemek_secim_sistemi.Models.StockItem>;
}

<form action="@Url.Action("AddRecipe", "Recipe")" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label fw-semibold">Yemek <span class="text-danger">*</span></label>
        <select name="FoodID" class="form-select py-2" required style="border-radius:8px;">
            <option value="">— Yemek Seçin —</option>
            @if (foods != null)
            {
                foreach (var f in foods)
                {
                    <option value="@f.ID">@f.Name</option>
                }
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Stok Malzemesi <span class="text-danger">*</span></label>
        <select name="StockItemID" class="form-select py-2" required style="border-radius:8px;">
            <option value="">— Malzeme Seçin —</option>
            @if (stockItems != null)
            {
                foreach (var s in stockItems)
                {
                    <option value="@s.ID">@s.Name (@s.Unit)</option>
                }
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Gereken Miktar <span class="text-danger">*</span></label>
        <input type="number" name="RequiredQuantity" class="form-control py-2" step="0.01" required placeholder="Örn: 2.5" style="border-radius:8px;" />
    </div>

    <div class="mb-4">
        <label class="form-label fw-semibold">Birim <span class="text-danger">*</span></label>
        <select name="Unit" class="form-select py-2" required style="border-radius:8px;">
            <option value="">— Birim Seçin —</option>
            <option value="kg">Kilogram (kg)</option>
            <option value="lt">Litre (lt)</option>
            <option value="adet">Adet</option>
            <option value="gr">Gram (gr)</option>
            <option value="ml">Mililitre (ml)</option>
        </select>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">İptal</button>
        <button type="submit" class="btn btn-primary" data-original-text="<i class='fa-solid fa-floppy-disk me-1'></i>Kaydet">
            <i class="fa-solid fa-floppy-disk me-1"></i>Kaydet
        </button>
    </div>
</form>