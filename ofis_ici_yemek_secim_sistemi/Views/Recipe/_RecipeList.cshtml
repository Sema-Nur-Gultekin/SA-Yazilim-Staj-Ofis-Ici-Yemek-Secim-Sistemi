@model IEnumerable<ofis_ici_yemek_secim_sistemi.Models.RecipeIngredient>
@{
    var foodNames = ViewBag.FoodNames as Dictionary<int, string>;
    var stockNames = ViewBag.StockNames as Dictionary<int, string>;
}

<div class="card shadow-sm border-0" style="border-radius:12px;">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="padding:1rem 1.5rem;">Yemek</th>
                    <th>Malzeme</th>
                    <th>Miktar</th>
                    <th>Birim</th>
                    <th style="min-width:120px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td style="padding:1rem 1.5rem;" class="fw-semibold text-dark">
                                @(foodNames != null && foodNames.ContainsKey(item.FoodID) ? foodNames[item.FoodID] : "Bilinmeyen")
                            </td>
                            <td>@(stockNames != null && stockNames.ContainsKey(item.StockItemID) ? stockNames[item.StockItemID] : "Bilinmeyen")</td>
                            <td>@item.RequiredQuantity.ToString("N2")</td>
                            <td>@item.Unit</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("EditRecipe", "Recipe", new { id = item.ID })"
                                       class="btn btn-sm btn-outline-primary btn-edit-ajax"
                                       data-title="Reçete Düzenle"
                                       title="Düzenle">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    @using (Html.BeginForm("DeleteRecipe", "Recipe", new { id = item.ID }, FormMethod.Post, new { @class = "d-inline" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil"
                                                onclick="return confirm('Bu reçete kaydını silmek istediğinize emin misiniz?')">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-book-open d-block fs-1 mb-2 text-black-50"></i>
                            Henüz bir reçete eklenmemiş.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>