@model List<ofis_ici_yemek_secim_sistemi.Controllers.MenuController.MenuGroupViewModel>
@{
    ViewBag.Title = "Menü Yönetimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-dark m-0">Menü Yönetimi</h3>
        <p class="text-muted small m-0">Günlük öğün planlarını ve yemekleri buradan yönetin.</p>
    </div>
    <a href="@Url.Action("AddMenu", "Menu")"
       class="btn btn-primary fw-bold px-4 py-2 shadow-sm btn-add-ajax"
       data-title="Yeni Menü Planla"
       style="border-radius: 12px;">
        <i class="fa-solid fa-plus me-2"></i>Yeni Menü Planla
    </a>
</div>

<div class="card shadow-sm border-0 mb-4 bg-white" style="border-radius: 16px;">
    <div class="card-body p-4">
        <div class="row g-4 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-bold text-secondary small mb-2">Tarihe Göre</label>
                <input type="date" id="dateFilter" class="form-control form-control-lg bg-light border-0 shadow-none"
                       value="@(ViewBag.Date != null ? ((DateTime)ViewBag.Date).ToString("yyyy-MM-dd") : "")"
                       style="border-radius: 12px; font-size: 0.95rem;" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-secondary small mb-2">Öğün Tipi</label>
                <select id="mealTypeFilter" class="form-select form-select-lg bg-light border-0 shadow-none" style="border-radius: 12px; font-size: 0.95rem;">
                    <option value="">— Tümü —</option>
                    <option value="Sabah" @(ViewBag.MealType == "Sabah" ? "selected" : "")>Sabah</option>
                    <option value="Öğle" @(ViewBag.MealType == "Öğle" ? "selected" : "")>Öğle</option>
                    <option value="Akşam" @(ViewBag.MealType == "Akşam" ? "selected" : "")>Akşam</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-secondary small mb-2">Yemek veya Kategori Ara</label>
                <div class="input-group input-group-lg bg-light" style="border-radius: 12px; overflow: hidden;">
                    <span class="input-group-text bg-transparent border-0 pe-1">
                        <i class="fa-solid fa-search text-muted"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control bg-transparent border-0 shadow-none"
                           placeholder="Örn: Karnıyarık, Tatlılar..."
                           value="@(ViewBag.Search ?? "")"
                           style="font-size: 0.95rem;" />
                </div>
            </div>
        </div>
    </div>
</div>

<div id="tableContainer" data-refresh-url="@Url.Action("MenuManagement", "Menu")">
    @Html.Partial("_MenuList", Model)
</div>

@section scripts {
    <script>
        $(function () {
      
            function applyFilters() {
                var date = $('#dateFilter').val();
                var mealType = $('#mealTypeFilter').val();
                var search = $('#searchInput').val();

                $.get('@Url.Action("MenuManagement", "Menu")', {
                    date: date || null,
                    mealType: mealType || null,
                    search: search || null
                }, function (html) {
                    $('#tableContainer').html(html);
                });
            }

            $('#dateFilter, #mealTypeFilter').on('change', applyFilters);

            var searchTimer;
            $('#searchInput').on('keyup', function () {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(applyFilters, 400); 
            });


     
            $(document).on('click', '.btn-toggle-status', function (e) {
                e.preventDefault();
                var btn = $(this);
                var form = btn.closest('form');
                var card = btn.closest('.menu-card');

                var isPast = card.data('is-past') === true || card.data('is-past') === 'true';
                var hasSelection = card.data('has-selection') === true || card.data('has-selection') === 'true';

                var isActive = card.data('is-active') === true || card.data('is-active') === 'true';
                var newStatusText = isActive ? 'pasif' : 'aktif';

                if (!isPast && hasSelection) {
                    Swal.fire({
                        title: 'Dikkat!',
                        text: 'Bu menüde halihazırda personel seçimleri bulunuyor. Durumu değiştirmek istediğinize emin misiniz?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Evet, ' + newStatusText + ' yap',
                        cancelButtonText: 'Vazgeç',
                        buttonsStyling: false,
                        customClass: {
                            confirmButton: 'btn btn-warning text-dark px-4 py-2 mx-2 rounded-3 fw-bold shadow-sm',
                            cancelButton: 'btn btn-light px-4 py-2 mx-2 rounded-3 text-secondary fw-semibold'
                        }
                    }).then((result) => {
                        if (result.isConfirmed) sendToggleRequest(form);
                    });
                } else {
                    Swal.fire({
                        title: 'Durum Değişikliği',
                        text: 'Menüyü ' + newStatusText + ' hale getirmek istediğinize emin misiniz?',
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Evet, değiştir',
                        cancelButtonText: 'Vazgeç',
                        buttonsStyling: false,
                        customClass: {
                            confirmButton: 'btn btn-primary px-4 py-2 mx-2 rounded-3 fw-bold shadow-sm',
                            cancelButton: 'btn btn-light px-4 py-2 mx-2 rounded-3 text-secondary fw-semibold'
                        }
                    }).then((result) => {
                        if (result.isConfirmed) sendToggleRequest(form);
                    });
                }
            });

            function sendToggleRequest(form) {
                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            toastr.success(response.message);
                            applyFilters(); 
                        } else {
                            Swal.fire({
                                title: 'Hata',
                                text: response.message,
                                icon: 'error',
                                buttonsStyling: false,
                                customClass: { confirmButton: 'btn btn-danger px-4 py-2 rounded-3 fw-bold' }
                            });
                        }
                    },
                    error: function () {
                        toastr.error('Sunucu ile iletişim kurulamadı.');
                    }
                });
            }


  
            $(document).on('click', '.btn-delete-menu', function (e) {
                e.preventDefault();
                var btn = $(this);
                var form = btn.closest('form');
                var card = btn.closest('.menu-card');

                var dateStr = form.find('input[name="date"]').val();
                var mealStr = form.find('input[name="mealType"]').val();
                var isPast = card.data('is-past') === true || card.data('is-past') === 'true';
                var hasSelection = card.data('has-selection') === true || card.data('has-selection') === 'true';

                var message = `<strong>${dateStr} - ${mealStr}</strong> menüsünü sistemden tamamen silmek istediğinize emin misiniz?`;
                var icon = 'warning';
                var confirmText = 'Evet, tamamen sil';
                var confirmBtnClass = 'btn btn-danger px-4 py-2 mx-2 rounded-3 fw-bold shadow-sm';

                if (!isPast && hasSelection) {
                    message = `Bu menüde <strong>personel seçimleri</strong> bulunmaktadır! Silme işlemi devam ederse bu seçimler de geçersiz kalacaktır. Yine de silmek istiyor musunuz?`;
                    icon = 'error';
                    confirmText = 'Riskli, Yinede Sil';
                    confirmBtnClass = 'btn btn-dark px-4 py-2 mx-2 rounded-3 fw-bold shadow-sm';
                }

                Swal.fire({
                    title: 'Silme Onayı',
                    html: message,
                    icon: icon,
                    showCancelButton: true,
                    confirmButtonText: confirmText,
                    cancelButtonText: 'Vazgeç',
                    buttonsStyling: false,
                    customClass: {
                        confirmButton: confirmBtnClass,
                        cancelButton: 'btn btn-light px-4 py-2 mx-2 rounded-3 text-secondary fw-semibold'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: form.attr('action'),
                            type: 'POST',
                            data: form.serialize(),
                            success: function (response) {
                                if (response.success) {
                                    toastr.success(response.message);
                                    applyFilters(); 
                                } else {
                                    Swal.fire({
                                        title: 'Hata',
                                        text: response.message,
                                        icon: 'error',
                                        buttonsStyling: false,
                                        customClass: { confirmButton: 'btn btn-danger px-4 py-2 rounded-3 fw-bold' }
                                    });
                                }
                            },
                            error: function () {
                                toastr.error('Silme işlemi sırasında sunucu hatası oluştu.');
                            }
                        });
                    }
                });
            });

        });
    </script>
}